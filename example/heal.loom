script "HealCommand" {
  command "heal" {
    if (argCount == 0) {
      sender.heal()
      sender.feed()
      sender.message("§aYou have been fully healed.")
      return
    }

    var target = player(args[0])
    if (target == null) {
      sender.message("§cNo player named §f" + args[0] + " §cis online.")
      return
    }

    target.heal()
    target.feed()
    sender.message("§aHealed §f" + target.name + "§a.")
    target.message("§aYou were healed by §f" + sender.name + "§a.")
  }
}
